# Creativals OS — frontend environment (Next.js)
#
# IMPORTANT: NEXT_PUBLIC_* variables are inlined AT BUILD TIME. Set them
# BEFORE `npx next build` — changing them afterwards has no effect until you
# rebuild. A production build without NEXT_PUBLIC_API_URL silently falls back
# to http://localhost:8000/api/v1 (a runtime console warning flags this).

# Base URL of the Laravel API, including the /api/v1 prefix.
# Local dev: http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# Master switch for the AI Assistant surface (sidebar entry, topbar shortcut,
# command palette, dashboard briefing panel). Set to "false" to hide every AI
# entry point. Whether a REAL model responds is separately driven by the
# backend's GEMINI_API_KEY/OPENAI_API_KEY — the UI shows an honest "Simulation mode" banner
# when the flag is on but no key is configured (see GET /ai/status).
NEXT_PUBLIC_AI_ENABLED=true

# Shown in the browser tab/branding.
NEXT_PUBLIC_APP_NAME=Creativals OS

# Laravel Reverb websocket endpoint (reserved for the Phase-Next realtime
# features — see the chat architecture note in PROJECT_AUDIT.md).
NEXT_PUBLIC_REVERB_HOST=api.yourdomain.com
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=wss
